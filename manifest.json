{
	"manifest_version": 3,
	"name": "Grindr Web Unlock",
	"homepage_url": "https://git.opengrind.org/open-grind/grindr-web-unlock",
	"version": "1.0.3",
	"description": "Unlock web.grindr.com for free users",
	"browser_specific_settings": {
		"gecko": {
			"id": "unlock-web.grindr.com@opengrind.org",
			"data_collection_permissions": {
				"required": ["none"],
				"optional": []
			}
		}
	},
	"icons": {
		"256": "icons/icon256.png",
		"128": "icons/icon128.png",
		"48": "icons/icon48.png",
		"32": "icons/icon32.png",
		"16": "icons/icon16.png"
	},
	"content_scripts": [
		{
			"matches": [
				"https://web.grindr.com/*"
			],
			"js": [
				"src/cookie-guard.js",
				"src/unlock.js"
			],
			"run_at": "document_start",
			"world": "MAIN",
			"all_frames": false
		}
	]
}